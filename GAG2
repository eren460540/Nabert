-- 7. AUTO BUY SEED & PLANT LOOP (Based on b2T31RHX.txt)
-- =============================================================================
task.spawn(function()
    local mythicShopPrompt = nil
    local superShopPrompt = nil
    local plantPrompts = {}

    while true do
        task.wait(0.5)
        if _G.GAG2_ThreadID ~= currentThread then break end

        -- Refresh shop and plant prompts
        pcall(function()
            mythicShopPrompt = nil
            superShopPrompt = nil
            plantPrompts = {}

            for _, p in pairs(workspace:GetDescendants()) do
                if p:IsA("ProximityPrompt") then
                    local act = string.lower(tostring(p.ActionText))
                    local pName = string.lower(p.Parent.Name)

                    if string.find(act, "plant") or string.find(act, "tanam") or string.find(act, "sow") then
                        if p.Parent:IsA("BasePart") then
                            table.insert(plantPrompts, p)
                        end
                    elseif string.find(pName, "mythic") and (string.find(act, "buy") or string.find(act, "seed")) then
                        mythicShopPrompt = p
                    elseif string.find(pName, "super") and (string.find(act, "buy") or string.find(act, "seed")) then
                        superShopPrompt = p
                    end
                end
            end
        end)

        if _G.AutoPlant then
            local root = getRootPart()
            local wallet = getPlayerWallet()
            local targetShop = nil

            -- Determine which seed to buy based on wallet
            if wallet >= _G.HargaSeedMythic and mythicShopPrompt then
                targetShop = mythicShopPrompt
            elseif wallet >= _G.HargaSeedSuper and superShopPrompt then
                targetShop = superShopPrompt
            end

            -- Buy seed if possible
            if targetShop and targetShop.Parent and root then
                teleportTo(targetShop.Parent.CFrame * CFrame.new(0, 2, 0))
                task.wait(0.3)
                fireproximityprompt(targetShop)
                task.wait(0.3)
            end

            -- Plant on empty plots
            if #plantPrompts > 0 and root then
                local activePlot = plantPrompts[1]
                if activePlot and activePlot.Parent then
                    teleportTo(activePlot.Parent.CFrame * CFrame.new(0, 2, 0))
                    task.wait(0.3)
                    fireproximityprompt(activePlot)
                    task.wait(0.1)
                end
            end
        end
    end
end)

