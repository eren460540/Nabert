task.spawn(function()
    while true do
        task.wait(0.3)
        if _G.GAG2_ThreadID ~= currentThread then break end

        if _G.AutoFarm then
            local root = getRootPart()
            if root then
                -- Harvest nearby crops
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") and _G.AutoFarm then
                        local parentName = string.lower(v.Parent.Name)
                        if string.find(parentName, "fruit") or string.find(parentName, "harvest") or
                           v.ObjectText == "Harvest" or v.ActionText == "Harvest" then
                            teleportTo(v.Parent.CFrame * CFrame.new(0, 2, 0))
                            task.wait(0.2)
                            fireproximityprompt(v)
                            task.wait(0.1)
                        end
                    end
                end
            end
        else
            task.wait(1)
        end
    end
end)

-- Auto Sell (every 15 seconds when inventory is full)
task.spawn(function()
    while true do
        task.wait(15)
        if _G.GAG2_ThreadID ~= currentThread then break end

        if _G.AutoFarm and checkInventoryFull() then
            local root = getRootPart()
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and string.find(string.lower(obj.Name), "sell") and root then
                    local lastPos = root.CFrame
                    teleportTo(obj.CFrame * CFrame.new(0, 3, 0))
                    task.wait(1.5)
                    -- Trigger sell prompt
                    for _, p in pairs(workspace:GetDescendants()) do
                        if p:IsA("ProximityPrompt") and string.find(string.lower(p.ActionText), "sell") then
                            fireproximityprompt(p)
                            break
                        end
                    end
                    task.wait(1)
                    root.CFrame = lastPos
                    break
                end
            end
        end
    end
end)

